# URL pública del sitio (sin barra final). Opcional en build de producción: si no se define,
# se usa la misma URL por defecto que en seo.constants (productionSiteOrigin).
# Definila en el hosting si el dominio difiere o querés forzar otro valor.
NUXT_PUBLIC_SITE_URL=https://estudiojuridicomz.com.ar
